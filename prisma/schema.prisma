generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Author {
  id        Int     @id @default(autoincrement())
  name      String
  bio       String?
  avatarUrl String?
  posts     Post[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String
  slug  String @unique
  posts Post[]
}

model Post {
  id                           Int         @id @default(autoincrement())
  title                        String
  slug                         String      @unique
  badge                        String?
  excerpt                      String?
  content                      String      @db.Text
  imageUrl                     String?
  facebookUrl                  String?
  linkedinUrl                  String?
  twitterUrl                   String?
  youtubeUrl                   String?
  email                        String?
  whatsappNumber               String?
  authorId                     Int?
  companyId                    Int?
  categoryId                   Int
  status                       Post_status @default(PENDING)
  createdById                  Int?
  approvedById                 Int?
  approvedAt                   DateTime?
  publishedAt                  DateTime?
  views                        Int         @default(0)
  shares                       Int         @default(0)
  createdAt                    DateTime    @default(now())
  updatedAt                    DateTime    @updatedAt
  comments                     Comment[]
  User_Post_approvedByIdToUser User?       @relation("Post_approvedByIdToUser", fields: [approvedById], references: [id])
  author                       Author?     @relation(fields: [authorId], references: [id])
  category                     Category    @relation(fields: [categoryId], references: [id])
  Company                      Company?    @relation(fields: [companyId], references: [id])
  User_Post_createdByIdToUser  User?       @relation("Post_createdByIdToUser", fields: [createdById], references: [id])

  @@index([approvedById])
  @@index([authorId])
  @@index([categoryId])
  @@index([companyId])
  @@index([createdById])
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  name      String
  email     String?
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])

  @@index([postId])
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  password            String
  role                String    @default("candidate")
  emailVerified       Boolean   @default(false)
  otpHash             String?
  otpExpiry           DateTime?
  resetOtpHash        String?
  resetOtpExpiry      DateTime?
  failedLoginAttempts Int       @default(0)
  lockUntil           DateTime?
  createdAt           DateTime  @default(now())
  username            String    @unique
  fullName            String?
  headline            String?
  about               String?   @db.Text
  location            String?
  avatarUrl           String?
  websiteUrl          String?
  isOnboarded         Boolean   @default(false)
  companyId           Int?
  packageSelected     Boolean   @default(false)
  emailSentForBulkImport Boolean @default(false) 
  lastLoginAt            DateTime?

  // ✅ RBAC: account can be deactivated without deleting it (used for sub-admins)
  isActive            Boolean   @default(true)
  roleId Int?

  roleTemplate Role? @relation(fields: [roleId], references: [id])

  skills CandidateSkill[]

  experiences CandidateExperience[]

  education CandidateEducation[]

  projects CandidateProject[]

  certifications CandidateCertification[]

  languages CandidateLanguage[]

  socials CandidateSocial[]

  interests CandidateInterest[]

  achievements CandidateAchievement[]


  AdvertisementBanner AdvertisementBanner[]
  CompanyFollower     CompanyFollower[]

  Event_Event_approvedByIdToUser Event[] @relation("Event_approvedByIdToUser")
  Event_Event_createdByIdToUser  Event[] @relation("Event_createdByIdToUser")

  Job            Job[]
  JobApplication JobApplication[]
  SavedJob       SavedJob[]
  JobAlert       JobAlert[]

  Magazine Magazine[]

  NewsletterSubscriber NewsletterSubscriber[]
  NewsletterCampaign   NewsletterCampaign[]
  NewsletterTemplate   NewsletterTemplate[]
  

  Post_Post_approvedByIdToUser Post[] @relation("Post_approvedByIdToUser")
  Post_Post_createdByIdToUser  Post[] @relation("Post_createdByIdToUser")

  SupplierDirectory_SupplierDirectory_approvedByIdToUser  SupplierDirectory[] @relation("SupplierDirectory_approvedByIdToUser")
  SupplierDirectory_SupplierDirectory_submittedByIdToUser SupplierDirectory[] @relation("SupplierDirectory_submittedByIdToUser")

  Company Company? @relation(fields: [companyId], references: [id])

  PackagePurchase PackagePurchase[]

  teamMemberships     CompanyTeamMember[] @relation("TeamMemberUser")
  approvedTeamMembers CompanyTeamMember[] @relation("TeamMemberApprovedBy")

  // ✅ RBAC: permissions this user has been granted (relevant for role = "sub_admin"),
  // and permissions this user has granted to others (relevant for role = "super_admin"/"admin")
  userPermissions     UserPermission[] @relation("UserPermissions")
  grantedPermissions  UserPermission[] @relation("PermissionGrantedBy")

  @@index([companyId])
}

model CandidateSkill {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String
  level       String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CandidateExperience {
  id               Int       @id @default(autoincrement())
  userId           Int

  companyId        Int?
  companyName      String

  designation      String

  employmentType   String?

  location         String?

  startDate        DateTime

  endDate          DateTime?

  currentlyWorking Boolean @default(false)

  description      String? @db.Text

  user User @relation(fields:[userId],references:[id],onDelete:Cascade)

  company Company? @relation(fields:[companyId],references:[id])

  @@index([userId])

  @@index([companyId])
}

model CandidateEducation {

  id Int @id @default(autoincrement())

  userId Int

  institution String

  degree String

  fieldOfStudy String?

  startYear Int?

  endYear Int?

  grade String?

  description String? @db.Text

  user User @relation(fields:[userId],references:[id],onDelete:Cascade)

  @@index([userId])
}

model CandidateProject {

  id Int @id @default(autoincrement())

  userId Int

  title String

  role String?

  description String? @db.Text

  imageUrl String?

  websiteUrl String?

  githubUrl String?

  technologies Json?

  startDate DateTime?

  endDate DateTime?

  user User @relation(fields:[userId],references:[id],onDelete:Cascade)

  @@index([userId])
}

model CandidateCertification {

  id Int @id @default(autoincrement())

  userId Int

  title String

  organization String?

  issueDate DateTime?

  expiryDate DateTime?

  credentialUrl String?

  user User @relation(fields:[userId],references:[id],onDelete:Cascade)

  @@index([userId])
}

model CandidateLanguage{

id Int @id @default(autoincrement())

userId Int

language String

proficiency String

user User @relation(fields:[userId],references:[id],onDelete:Cascade)

@@index([userId])
}

model CandidateSocial{

id Int @id @default(autoincrement())

userId Int

platform String

url String

user User @relation(fields:[userId],references:[id],onDelete:Cascade)

@@index([userId])
}

model CandidateInterest{

id Int @id @default(autoincrement())

userId Int

title String

type String?

user User @relation(fields:[userId],references:[id],onDelete:Cascade)

@@index([userId])
}

model CandidateAchievement{

id Int @id @default(autoincrement())

userId Int

title String

description String?

achievementDate DateTime?

user User @relation(fields:[userId],references:[id],onDelete:Cascade)

@@index([userId])
}

model AdvertisementBanner {
  id          Int                           @id @default(autoincrement())
  title       String
  imageUrl    String
  targetUrl   String?
  placement   AdvertisementBanner_placement
  status      AdvertisementBanner_status    @default(INACTIVE)
  position    Int                           @default(0)
  startDate   DateTime?
  endDate     DateTime?
  impressions Int                           @default(0)
  clicks      Int                           @default(0)
  createdById Int
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime
  User        User                          @relation(fields: [createdById], references: [id])

  @@index([createdById])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int?
  userId    Int?
  createdAt DateTime @default(now())
}

model Company {
  id                    Int                    @id @default(autoincrement())
  name                  String
  slug                  String                 @unique
  tagline               String?
  description           String?
  location              String?
  companySize           String?
  website               String?
  logoUrl               String?
  coverImageUrl         String?
  isVerified            Boolean                @default(false)
  createdAt             DateTime               @default(now())
  industryId            Int?
  address               String?
  Industry              Industry?              @relation(fields: [industryId], references: [id])
  CompanyFollower       CompanyFollower[]
  Job                   Job[]
  Post                  Post[]
  SupplierDirectory     SupplierDirectory[]
  candidateExperiences CandidateExperience[]

  User                  User[]
  PackagePurchase       PackagePurchase[]
  subscriptionPlan      String                 @default("free")
  subscriptionExpiresAt DateTime?
  NewsletterSubscriber  NewsletterSubscriber[]
  teamMembers           CompanyTeamMember[]
  jobPostingCredits     Int                    @default(0)

  @@index([industryId])
}

model CompanyTeamMember {
  id              Int              @id @default(autoincrement())
  companyId       Int
  userId          Int
  designation     String
  department      String?
  employmentType  String?
  startDate       DateTime?
  endDate         DateTime?
  status          TeamMemberStatus @default(PENDING)
  approvedById    Int?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user            User             @relation("TeamMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy      User?            @relation("TeamMemberApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
  @@index([status])
}

model PackagePurchase {
  id                Int                    @id @default(autoincrement())
  userId            Int
  companyId         Int?
  packageType       PackagePurchase_type
  packageId         String
  packageName       String
  amount            Int
  currency          String                 @default("INR")
  status            PackagePurchase_status @default(PENDING)
  razorpayOrderId   String?                @unique
  razorpayPaymentId String?
  metadata          Json?
  startsAt          DateTime?
  expiresAt         DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  User              User                   @relation(fields: [userId], references: [id])
  Company           Company?               @relation(fields: [companyId], references: [id])

  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([packageType])
}

model CompanyFollower {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  createdAt DateTime @default(now())
  Company   Company  @relation(fields: [companyId], references: [id])
  User      User     @relation(fields: [userId], references: [id])

  @@unique([companyId, userId])
  @@index([userId])
}

model CoverStory {
  id               Int             @id @default(autoincrement())
  title            String
  slug             String          @unique
  shortDescription String?
  keyCategories    Json?
  imageBrief       String?
  fullDescription  String          @db.Text
  badge            String?
  coverImageUrl    String?
  slugImageUrls    Json?
  createdAt        DateTime        @default(now())
  authorId         Int?
  MagazineAuthor   MagazineAuthor? @relation(fields: [authorId], references: [id])
  Magazine         Magazine[]

  @@index([authorId])
}

model Event {
  id                            Int                 @id @default(autoincrement())
  title                         String
  slug                          String              @unique
  logoUrl                       String?
  bannerUrl                     String?
  startDate                     DateTime
  endDate                       DateTime
  description                   String              @db.Text
  websiteUrl                    String?
  registerUrl                   String?
  location                      String?
  calendarUrl                   String?
  status                        Event_status        @default(DRAFT)
  views                         Int                 @default(0)
  createdById                   Int
  approvedById                  Int?
  createdAt                     DateTime            @default(now())
  updatedAt                     DateTime
  publishedAt                   DateTime?
  User_Event_approvedByIdToUser User?               @relation("Event_approvedByIdToUser", fields: [approvedById], references: [id])
  User_Event_createdByIdToUser  User                @relation("Event_createdByIdToUser", fields: [createdById], references: [id])
  EventRegistration             EventRegistration[]

  @@index([approvedById])
  @@index([createdById])
}

model EventRegistration {
  id                  Int      @id @default(autoincrement())
  eventId             Int
  fullName            String
  email               String
  phone               String
  companyName         String?
  jobTitle            String?
  country             String?
  city                String?
  industry            String?
  experience          String?
  attendeeType        String?
  ticketType          String?
  interests           Json?
  specialRequirements String?  @db.Text
  status              String   @default("REGISTERED")
  createdAt           DateTime @default(now())
  Event               Event    @relation(fields: [eventId], references: [id])

  @@index([eventId])
}

model Industry {
  id             Int        @id @default(autoincrement())
  name           String
  slug           String     @unique
  parentId       Int?
  createdAt      DateTime   @default(now())
  Company        Company[]
  Industry       Industry?  @relation("IndustryToIndustry", fields: [parentId], references: [id])
  other_Industry Industry[] @relation("IndustryToIndustry")

  @@index([parentId])
}

model Job {
  id             Int              @id @default(autoincrement())
  title          String
  slug           String           @unique
  description    String           @db.Text
  employmentType String
  experience     String?
  salaryRange    String?
  location       String
  isRemote       Boolean          @default(false) 
  isActive       Boolean          @default(true)
  views          Int              @default(0)
  isFeatured     Boolean          @default(false)   
  featuredAt     DateTime?                           
  companyId      Int?
  postedById     Int
  createdAt      DateTime         @default(now())
  applyUrl       String?
  isExternal     Boolean          @default(false)
  linkedinUrl    String?
  companyName    String?
  Company        Company?         @relation(fields: [companyId], references: [id])
  User           User             @relation(fields: [postedById], references: [id])
  JobApplication JobApplication[]
  SavedJob       SavedJob[]

  @@index([companyId])
  @@index([postedById])
}

model SavedJob {
  id        Int      @id @default(autoincrement())
  jobId     Int
  userId    Int
  createdAt DateTime @default(now())
  Job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([userId])
}

model JobAlert {
  id             Int      @id @default(autoincrement())
  userId         Int
  name           String?
  keywords       String?
  location       String?
  employmentType String?
  isRemote       Boolean?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model JobApplication {
  id        Int      @id @default(autoincrement())
  jobId     Int
  userId    Int
  resumeUrl String?
  coverNote String?
  status    String   @default("applied")
  createdAt DateTime @default(now())
  Job       Job      @relation(fields: [jobId], references: [id])
  User      User     @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
  @@index([userId])
}

model Magazine {
  id                   Int                    @id @default(autoincrement())
  title                String
  slug                 String                 @unique
  description          String?                @db.Text
  coverImageUrl        String?
  pdfUrl               String
  flipbookPages        Json?
  status               Magazine_status        @default(DRAFT)
  createdById          Int
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  publishedAt          DateTime?
  authorId             Int?
  coverStoryId         Int?
  MagazineAuthor       MagazineAuthor?        @relation(fields: [authorId], references: [id])
  CoverStory           CoverStory?            @relation(fields: [coverStoryId], references: [id])
  User                 User                   @relation(fields: [createdById], references: [id])
  MagazineRegistration MagazineRegistration[]

  @@index([authorId])
  @@index([coverStoryId])
  @@index([createdById])
}

model MagazineAuthor {
  id              Int          @id @default(autoincrement())
  name            String
  profileImageUrl String?
  designation     String?
  linkedinUrl     String?
  createdAt       DateTime     @default(now())
  CoverStory      CoverStory[]
  Magazine        Magazine[]
}

model MagazineRegistration {
  id          Int      @id @default(autoincrement())
  magazineId  Int
  firstName   String
  lastName    String
  email       String
  companyName String?
  jobTitle    String?
  country     String?
  createdAt   DateTime @default(now())
  Magazine    Magazine @relation(fields: [magazineId], references: [id])

  @@index([magazineId])
}

model SupplierDirectory {
  id                                         Int                      @id @default(autoincrement())
  name                                       String
  slug                                       String                   @unique
  companyId                                  Int?
  phoneNumber                                String?
  email                                      String?
  website                                    String?
  googleMapUrl                               String?                  @db.Text
  logoUrl                                    String?
  coverImageUrl                              Json?
  description                                String                   @db.Text
  tradeNames                                 Json?
  socialLinks                                Json?
  videoGallery                               Json?
  productSupplies                            Json?
  productGallery                             Json?
  companyGallery                             Json?
  factoryGallery                             Json?
  productCatalogues                          Json?
  companyBrochure                            Json?
  certifications                             Json?
  brandsRepresented                          Json?
  industriesServed                           Json?
  exportMarkets                              Json?
  manufacturingCapabilities                  String?                  @db.Text
  machineryList                              String?                  @db.Text
  qualityStandards                           String?                  @db.Text
  enableInquiryForm                          Boolean                  @default(true)
  status                                     SupplierDirectory_status @default(PENDING)
  isLiveEditable                             Boolean                  @default(false)
  views                                      Int                      @default(0)
  connections                                Int                      @default(0)
  submittedById                              Int
  approvedById                               Int?
  createdAt                                  DateTime                 @default(now())
  approvedAt                                 DateTime?
  isFeatured                                 Boolean                  @default(false)
  User_SupplierDirectory_approvedByIdToUser  User?                    @relation("SupplierDirectory_approvedByIdToUser", fields: [approvedById], references: [id])
  Company                                    Company?                 @relation(fields: [companyId], references: [id])
  User_SupplierDirectory_submittedByIdToUser User                     @relation("SupplierDirectory_submittedByIdToUser", fields: [submittedById], references: [id])
  
  manufacturingCapabilityImages              Json?                    // NEW: Array of image URLs
  manufacturingCapabilityVideos              Json?                    // NEW: Array of video URLs
  machineryImages                            Json?                    // NEW: Array of image URLs

  @@index([approvedById])
  @@index([companyId])
  @@index([submittedById])
}

model NewsletterSubscriber {
  id                  Int                        @id @default(autoincrement())
  fullName            String?
  email               String?                    @unique
  phoneNumber         String?
  companyName         String?
  userId              Int?
  companyId           Int?
  source              NewsletterSubscriberSource
  emailSubscribed     Boolean                    @default(true)
  whatsappSubscribed  Boolean                    @default(false)
  smsSubscribed       Boolean                    @default(false)
  frequency           NewsletterFrequency        @default(MONTHLY)
  status              NewsletterStatus           @default(ACTIVE)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  User                User?                      @relation(fields: [userId], references: [id])
  Company             Company?                   @relation(fields: [companyId], references: [id])
  NewsletterRecipient NewsletterRecipient[]

  @@index([email])
  @@index([phoneNumber])
  @@index([companyId])
  @@index([userId])
}

model NewsletterCampaign {
  id                  Int                   @id @default(autoincrement())
  title               String
  subject             String
  content             String                @db.Text
  coverImage          String?
  emailEnabled        Boolean               @default(true)
  whatsappEnabled     Boolean               @default(false)
  smsEnabled          Boolean               @default(false)
  frequency           NewsletterFrequency?
  scheduledAt         DateTime?
  sentAt              DateTime?
  status              CampaignStatus        @default(DRAFT)
  totalRecipients     Int                   @default(0)
  delivered           Int                   @default(0)
  opened              Int                   @default(0)
  clicked             Int                   @default(0)
  failed              Int                   @default(0)
  createdById         Int
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  User                User                  @relation(fields: [createdById], references: [id])
  NewsletterRecipient NewsletterRecipient[]

  @@index([status])
}

model NewsletterRecipient {
  id                   Int                  @id @default(autoincrement())
  campaignId           Int
  subscriberId         Int
  emailStatus          DeliveryStatus       @default(PENDING)
  whatsappStatus       DeliveryStatus       @default(PENDING)
  smsStatus            DeliveryStatus       @default(PENDING)
  sentAt               DateTime?
  openedAt             DateTime?
  clickedAt            DateTime?
  NewsletterCampaign   NewsletterCampaign   @relation(fields: [campaignId], references: [id])
  NewsletterSubscriber NewsletterSubscriber @relation(fields: [subscriberId], references: [id])

  @@unique([campaignId, subscriberId])
  @@index([campaignId])
  @@index([subscriberId])
}
model Lead {
  id          Int         @id @default(autoincrement())
  source      Lead_source
  contactId   Int?
  supplierId  Int?
  userId      Int?
  companyId   Int?
  fullName    String
  email       String
  phoneNumber String?
  website     String?
  companyName String?
  message     String      @db.Text
  hasPackage  Boolean     @default(false)
  planName    String?
  status      LeadStatus  @default(NEW)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([contactId])
  @@index([supplierId])
  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([source])
}
model Package {
  id            String   @id @default(cuid())
  name          String
  type          PackageType
  price         Int
  billingCycle  BillingCycle
  description   String?
  badge         String?
  displayOrder  Int      @default(0)
  isHighlighted Boolean  @default(false)
  isActive      Boolean  @default(true)
  metadata      Json?    // For additional data like durationDays, features, etc.
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@index([type])
  @@index([isActive])
  @@index([displayOrder])
}
model Role {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(100)
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
  rolePermissions RolePermission[]
}
model RolePermission {
  id           Int @id @default(autoincrement())

  roleId       Int
  permissionId Int

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model NewsletterTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  subject     String
  content     String   @db.Text
  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  User        User     @relation(fields: [createdById], references: [id])
}

// =====================================================================
// ✅ RBAC ADDITIONS (Permission / UserPermission) — everything above
// this line is unchanged from the original schema.
// =====================================================================

model Permission {

  id              Int @id @default(autoincrement())
  key             String @unique
  label           String?
  module          String?
  createdAt       DateTime @default(now())

  userPermissions UserPermission[]
  rolePermissions RolePermission[]

  @@index([module])
}

model UserPermission {
  id           Int      @id @default(autoincrement())
  userId       Int
  permissionId Int
  grantedById  Int?
  granted      Boolean  @default(true) 
  createdAt    DateTime @default(now())

  user       User       @relation("UserPermissions", fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedBy  User?      @relation("PermissionGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
  @@index([grantedById])
}

enum AdvertisementBanner_placement {
  HOME_TOP
  HOME_MIDDLE
  HOME_BOTTOM
  ARTICLE_TOP
  ARTICLE_MIDDLE
  ARTICLE_BOTTOM
  SUPPLIER_TOP
  SUPPLIER_AFTER_VIDEO
  SIDEBAR
  FOOTER
  EVENT_RIGHT
  SUPPLIER_RIGHT
  JOB_RIGHT
  INDUSTRY_TALKS_RIGHT
  MAGAZINE_RIGHT
  Archive
}

enum PackageType {
  SUBSCRIPTION
  BANNER
  SPONSORED
  RECRUITMENT
}

enum BillingCycle {
  MONTHLY
